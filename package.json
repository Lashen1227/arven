{
  "name": "@lashen/arven",
  "version": "0.0.0-development",
  "description": "Watches over your env vars — scan & generate .env.example on every commit",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "arven": "./dist/bin/arven.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node --test dist/tests/arven.test.js",
    "pretest": "npm run build",
    "prepublishOnly": "npm run build",
    "semantic-release": "semantic-release"
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "env",
    "env-example",
    "git-hooks",
    "pre-commit",
    "cli",
    "developer-tools"
  ],
  "author": {
    "name": "Lashen Martino",
    "email": "lashenmartino@gmail.com",
    "url": "https://lashen.onrender.com"
  },
  "license": "MIT",
  "homepage": "https://arven-lashen.onrender.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/Lashen1227/arven.git"
  },
  "bugs": {
    "url": "https://github.com/Lashen1227/arven/issues"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "glob": "^10.3.10"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}